# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev<name>

NEXT_PUBLIC_CONVEX_URL=https://<name>.convex.cloud

NEXT_PUBLIC_CONVEX_SITE_URL=https://<name>.convex.site

# Used by Next.js proxy route (Edge runtime) — must also be set in Vercel
ENCRYPTION_KEY=
GEMINI_API_KEY=
PROXY_SECRET=              # Must match Convex env var

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://<us/eu>.i.posthog.com

# Rate limiting
UPSTASH_REDIS_REST_URL=https://<name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=
